# Browser-visible API base used by the React app.
# Local and Vercel should use /api so requests go through a same-origin proxy.
VITE_API_BASE_URL=/api

# Local Vite dev proxy target. For production Vercel, set BACKEND_API_URL instead.
VITE_BACKEND_URL=http://localhost:4000

# Public file URL origin. Use /api when proxying files, or the backend origin directly.
VITE_PUBLIC_API_ORIGIN=/api

# Server-side proxy target for Vercel api/[...path].js.
# In Vercel production, set this to https://api.vuapp.dev.
BACKEND_API_URL=http://localhost:4000
